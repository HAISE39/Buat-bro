local Config = {
    Active = true,
    HPTrigger = 80,
    BossMinHP = 100000000,
    M1Delay = 0.05,
}

local State = {
    Kills = 0,
    LastHit = 0,
    KillTriggered = false,
    CurrentBoss = nil,
}

-- ══════════════════════════════════════════
-- BOSS DETECTION dari BossUIUpdate
-- ══════════════════════════════════════════
local Remotes = RS:FindFirstChild("Remotes")
local BossUIUpdate = Remotes and Remotes:FindFirstChild("BossUIUpdate")
local ServerAnnouncement = Remotes and Remotes:FindFirstChild("ServerAnnouncement")

local CurrentBossHP = 0
local CurrentBossMaxHP = 0

if BossUIUpdate then
    BossUIUpdate.OnClientEvent:Connect(function(type, data)
        if type == "Health" then
            CurrentBossMaxHP = data.max
            CurrentBossHP = data.current
        end
    end)
end

if ServerAnnouncement then
    ServerAnnouncement.OnClientEvent:Connect(function(msg, type)
        if type == "WORLD_BOSS_DEATH" or string.find(msg, "defeated") then
            State.KillTriggered = false
            State.Kills = State.Kills + 1
            if KillDisp then KillDisp.Text = "💀 " .. State.Kills end
            task.wait(3)
            CurrentBossHP = 0
            CurrentBossMaxHP = 0
        end
    end)
end

-- ══════════════════════════════════════════
-- SEND M1 HIT
-- ══════════════════════════════════════════
local function SendM1(targetPos)
    if not RequestHit then return false end
    if tick() - State.LastHit < Config.M1Delay then return false end
    
    local success = false
    pcall(function()
        RequestHit:FireServer(targetPos)
        success = true
    end)
    
    if success then
        State.LastHit = tick()
    end
    
    return success
end

