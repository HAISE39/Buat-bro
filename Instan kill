            end
        end
    else
        if StatusText.Text ~= "● WAITING" and StatusText.Text ~= "● STAND BY" then
            StatusText.Text = "● WAITING FOR BOSS"
            StatusText.TextColor3 = Color3.fromRGB(150, 150, 150)
        end
        KillTriggered = false
    end
end)

