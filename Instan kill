-- ══════════════════════════════════════════
-- DRAG FUNCTION
-- ══════════════════════════════════════════
local dragActive = false
local dragStartPos = nil
local dragStartMouse = nil

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragActive = true
        dragStartPos = MainFrame.Position
        dragStartMouse = input.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragActive = false
            end
        end)
    end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if dragActive and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStartMouse
        MainFrame.Position = UDim2.new(
            dragStartPos.X.Scale,
            dragStartPos.X.Offset + delta.X,
            dragStartPos.Y.Scale,
            dragStartPos.Y.Offset + delta.Y
        )
    end
end)

-- ══════════════════════════════════════════
-- VARIABLES
-- ══════════════════════════════════════════
local Active = true
local HPTrigger = 80
local KillCount = 0
local KillTriggered = false
local LastAttack = 0
local AttackDelay = 0.05

-- Data boss dari UI update
local CurrentBossHP = 0
local CurrentBossMaxHP = 0

-- ══════════════════════════════════════════
-- BOSS UI UPDATE LISTENER
-- ══════════════════════════════════════════
local Remotes = RS:FindFirstChild("Remotes")
local BossUIUpdate = Remotes and Remotes:FindFirstChild("BossUIUpdate")
local ServerAnnounce = Remotes and Remotes:FindFirstChild("ServerAnnouncement")

if BossUIUpdate then
    BossUIUpdate.OnClientEvent:Connect(function(typ, data)
        if typ == "Health" then
            CurrentBossMaxHP = data.max
            CurrentBossHP = data.current
        end
    end)
end

if ServerAnnounce then
    ServerAnnounce.OnClientEvent:Connect(function(msg, typ)
        if typ == "WORLD_BOSS_DEATH" or string.find(msg, "defeated") then
            KillTriggered = false
            KillCount = KillCount + 1
            KillText.Text = "💀 " .. KillCount
            StatusText.Text = "✅ BOSS KILLED!"
            StatusText.TextColor3 = Color3.fromRGB(100, 255, 100)
            
            task.wait(3)
            CurrentBossHP = 0
            CurrentBossMaxHP = 0
            StatusText.Text = "● WAITING"
            StatusText.TextColor3 = Color3.fromRGB(150, 150, 150)
        end
    end)
end

-- ══════════════════════════════════════════
-- ATTACK FUNCTION
-- ══════════════════════════════════════════
local function Attack(pos)
    if not RequestHit then return false end
    if tick() - LastAttack < AttackDelay then return false end
    
    local success = false
    pcall(function()
        RequestHit:FireServer(pos)
        success = true
    end)
    
    if success then
        LastAttack = tick()
    end
    
    return success
end

-- ══════════════════════════════════════════
-- MAIN LOOP
-- ══════════════════════════════════════════
RunService.Heartbeat:Connect(function()
    if not Active then return end
    
    if CurrentBossMaxHP > 0 and CurrentBossHP > 0 then
        local hpPercent = (CurrentBossHP / CurrentBossMaxHP) * 100
        
        -- Update status text
        StatusText.Text = string.format("⚡ BOSS HP: %.1f%%", hpPercent)
        
        if hpPercent < HPTrigger then
            StatusText.TextColor3 = Color3.fromRGB(255, 70, 85)
        else
            StatusText.TextColor3 = Color3.fromRGB(255, 200, 100)
        end
        
        -- TRIGGER KILL
        if hpPercent < HPTrigger and not KillTriggered then
            KillTriggered = true
            StatusText.Text = "💀 KILLING BOSS..."
            StatusText.TextColor3 = Color3.fromRGB(255, 70, 85)
            
            -- Cari boss di workspace untuk posisi
            local found = false
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("Humanoid") and obj.MaxHealth >= 100000000 and obj.Health > 0 then
                    local model = obj.Parent
                    local root = model and (model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head"))
                    if root then
                        -- SPAM ATTACK 15x CEPAT
                        for i = 1, 15 do
                            Attack(root.Position)
                            task.wait(0.02)
                        end
                        found = true
                        break
                    end
                end
            end
            
            if found then
                StatusText.Text = "✓ ATTACK SENT!"
            else
                StatusText.Text = "✗ BOSS NOT FOUND"
