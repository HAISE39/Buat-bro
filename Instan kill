-- Fungsi baca status boss dari GUI Timer
local function GetBossStatus()
    local bosses = {}
    if BossTimerGui then
        local body = BossTimerGui:FindFirstChild("P"):FindFirstChild("Body")
        if body then
            for _, card in pairs(body:GetChildren()) do
                if card:IsA("Frame") and card.Name ~= "UIListLayout" and card.Name ~ tostring(card:FindFirstChildOfClass("UIListLayout")) then
                    -- Parse dari card
                    local nameLabel = card:FindFirstChildOfClass("TextLabel")
                    local timerLabel = nil
                    local barFill = nil
                    
                    for _, v in pairs(card:GetChildren()) do
                        if v:IsA("TextLabel") and v.TextSize == 15 then
                            timerLabel = v
                        end
                        if v:IsA("Frame") and v:FindFirstChildOfClass("Frame") then
                            barFill = v:FindFirstChildOfClass("Frame")
                        end
                    end
                    
                    if nameLabel and timerLabel then
                        local isAlive = timerLabel.Text == "LIVE"
                        bosses[nameLabel.Text] = {
                            isAlive = isAlive,
                            timer = timerLabel.Text,
                            barFill = barFill
                        }
                    end
                end
            end
        end
    end
    return bosses
end

-- ══════════════════════════════════════════
-- FIND BOSS IN WORKSPACE
-- ══════════════════════════════════════════
local function FindBossInWorkspace()
    local char = LP.Character
    if not char then return nil end
    
    local myRoot = char:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    
    -- Cari di berbagai folder
    local npcFolders = {
        workspace:FindFirstChild("NPCs"),
        workspace:FindFirstChild("Mobs"),
        workspace:FindFirstChild("Enemies"),
        workspace:FindFirstChild("Bosses"),
    }
    
    for _, folder in pairs(npcFolders) do
        if folder then
            for _, npc in pairs(folder:GetChildren()) do
                if npc:IsA("Model") then
                    local hum = npc:FindFirstChildOfClass("Humanoid")
                    local root = npc:FindFirstChild("HumanoidRootPart")
                    if hum and root and hum.Health > 0 then
                        -- Cek apakah ini boss (MaxHP tinggi)
                        if hum.MaxHealth >= 1000000 then
                            return npc, hum, root
                        end
                    end
                end
            end
        end
    end
    
    -- Fallback: cari semua model dengan Humanoid & MaxHealth besar
    for _, npc in pairs(workspace:GetDescendants()) do
        if npc:IsA("Model") and npc.Parent ~= LP.Character then
            local hum = npc:FindFirstChildOfClass("Humanoid")
            local root = npc:FindFirstChild("HumanoidRootPart")
            if hum and root and hum.Health > 0 and hum.MaxHealth >= 1000000 then
                return npc, hum, root
            end
        end
    end
    
    return nil
end

-- ══════════════════════════════════════════
-- ATTACK FUNCTION
-- ══════════════════════════════════════════
local LastAttack = 0
local AttackDelay = 0.05 -- 50ms antara attack (lebih cepat)

local function AttackTarget(targetRoot)
    if not AttackRemote then 
        -- Coba lagi cari remote
        AllRemotes = ScanRemotes()
        for _, r in pairs(AllRemotes) do
            local name = r.Name:lower()
            if name:find("hit") or name:find("m1") or name:find("attack") then
                AttackRemote = r
                break
            end
        end
        if not AttackRemote then return false end
    end
    
    if tick() - LastAttack < AttackDelay then return false end
    
    local targetPos = targetRoot.Position
    local success = false
    
    -- Coba berbagai metode
    pcall(function()
        AttackRemote:FireServer(targetPos)
        success = true
    end)
    
    pcall(function()
        AttackRemote:FireServer(targetPos, 999999999)
        success = true
    end)
    
    pcall(function()
        AttackRemote:FireServer(targetRoot.Parent, targetPos)
        success = true
    end)
    
    if success then
        LastAttack = tick()
    end
    
    return success
end

