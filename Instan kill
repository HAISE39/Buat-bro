-- KILL TRIGGER
-- ══════════════════════════════════════════
local Config = {
    Active = true,
    HPTrigger = 70,     -- Kill saat HP < 70%
    AbilityID = 1,      -- Skill 1 (dari spy: Skill 1 di slot 1)
}

local KillTriggered = false
local KillCount = 0

-- Fungsi untuk trigger kill
local function TriggerKill()
    if not RequestAbility then
        warn("[IK] RequestAbility remote not found!")
        return false
    end
    
    -- Kirim RequestAbility dengan damage besar
    -- Dari spy, damage bisa 458B, jadi kita kirim damage besar
    local success = false
    
    -- Method 1: Skill biasa
    pcall(function()
        RequestAbility:FireServer(Config.AbilityID)
        success = true
    end)
    
    -- Method 2: Skill dengan damage override
    pcall(function()
        RequestAbility:FireServer(Config.AbilityID, 999999999999)
        success = true
    end)
    
    -- Method 3: Skill dengan target + damage
    pcall(function()
        RequestAbility:FireServer(Config.AbilityID, LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") and LP.Character.HumanoidRootPart.Position)
        success = true
    end)
    
    return success
end

