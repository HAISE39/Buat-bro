-- MAIN LOOP
-- ══════════════════════════════════════════
local function UpdateDisplay()
    if CurrentBoss.MaxHP > 0 then
        local hpPercent = (CurrentBoss.CurrentHP / CurrentBoss.MaxHP) * 100
        BossHP.Text = string.format("HP: %s / %s (%.1f%%)", 
            tostring(CurrentBoss.CurrentHP):sub(1, 12), 
            tostring(CurrentBoss.MaxHP):sub(1, 12),
            hpPercent)
        
        Status.Text = string.format("⚡ Boss HP: %.1f%%", hpPercent)
        
        -- CEK KILL CONDITION
        if Config.Active and not KillTriggered and CurrentBoss.IsAlive then
            if hpPercent < Config.HPTrigger then
                Status.Text = "💀 TRIGGERING KILL..."
                Status.TextColor3 = Color3.fromRGB(255, 70, 85)
                
                local success = TriggerKill()
                
                if success then
                    KillTriggered = true
                    Status.Text = "✓ KILL TRIGGER SENT!"
                    
                    -- Tunggu konfirmasi mati
                    task.wait(2)
                    if not CurrentBoss.IsAlive then
                        KillCount = KillCount + 1
                        KillDisp.Text = "💀 " .. KillCount
                        Status.Text = "✅ BOSS KILLED!"
                        Status.TextColor3 = Color3.fromRGB(100, 255, 100)
                        KillTriggered = false
                    end
                else
                    Status.Text = "✗ TRIGGER FAILED"
                    Status.TextColor3 = Color3.fromRGB(255, 70, 85)
                end
            end
        end
    else
        BossHP.Text = "HP: Waiting for boss..."
        if not KillTriggered then
            Status.Text = "🔍 Waiting for world boss..."
            Status.TextColor3 = Color3.fromRGB(150, 150, 150)
        end
    end
end

-- Update setiap detik (biar ga terlalu berat)
